generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id        String   @id @default(cuid())
  name      String   @db.VarChar(100)
  baseUrl   String   @db.VarChar(500)
  createdAt DateTime @default(now())
  scans     Scan[]
}

model Scan {
  id          String     @id @default(cuid())
  projectId   String
  status      ScanStatus @default(pending)
  startedAt   DateTime?
  completedAt DateTime?
  pages       Page[]
  findings    Finding[]
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Page {
  id       String    @id @default(cuid())
  scanId   String
  url      String    @db.VarChar(1000)
  title    String?
  status   Int?
  scan     Scan      @relation(fields: [scanId], references: [id], onDelete: Cascade)
  findings Finding[]
}

model Rule {
  id       String    @id
  title    String
  wcagRefs String[]
  findings Finding[]
}

model Finding {
  id              String        @id @default(cuid())
  scanId          String
  pageId          String
  ruleId          String
  severity        Severity
  fingerprint     String
  selector        String?
  message         String
  status          FindingStatus @default(OPEN)
  waivedAt        DateTime?
  waivedReason    String?
  waivedExpiresAt DateTime?
  scan            Scan          @relation(fields: [scanId], references: [id])
  page            Page          @relation(fields: [pageId], references: [id])
  rule            Rule          @relation(fields: [ruleId], references: [id])
  evidence        Evidence?

  @@unique([scanId, fingerprint], name: "scan_fingerprint")
}

model Evidence {
  id         String  @id @default(cuid())
  findingId  String  @unique
  screenshot String  @db.VarChar(500)
  domSnippet String?
  meta       Json?
  finding    Finding @relation(fields: [findingId], references: [id], onDelete: Cascade)
}

enum ScanStatus {
  pending
  queued
  crawling
  analyzing
  diffing
  evidence
  completed
  failed
}

enum Severity {
  MINOR
  MODERATE
  SERIOUS
  CRITICAL
}

enum FindingStatus {
  OPEN
  FIXED
  REGRESSED
  WAIVED
}
